# Copy to .streamlit/secrets.toml and fill in real keys for local dev.
# AppTest tests set these in-test via at.secrets[...]; no .toml needed in CI.

FRED_API_KEY = "your-fred-api-key-here"
GEMINI_API_KEY = "your-gemini-api-key-here"

# ── 保單視圖 (P1.2 + P3) ────────────────────────────────────────────
# 設定步驟見 docs/POLICY_SHEETS_SETUP.md
# Schema：8 必填 + 1 選填（policy_tier, P3）共 9 欄
POLICY_SHEET_ID = "your-google-sheet-id-here"

[google_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
client_email = "your-bot@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
