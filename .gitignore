# Secrets - NEVER commit
.streamlit/secrets.toml

# Notebook (contains hardcoded API keys)
*.ipynb
.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
.env

# Temp / cache
temp/
*.pkl
*.cache
*.csv
*.xlsx
# runtime cache（Streamlit 容器重啟即清空 / 測試可能寫入 → 不入 repo）
cache/fund_history.json
cache/nav_history/
# 例外：範本檔需要 commit 進 repo
!templates/*.csv
!templates/*.xlsx

# OS
.DS_Store
Thumbs.db

# Debug protocol artifacts (Phase 1-4 generated, cleaned at Phase 4)
*.bak
debug.log

# 一次性 git push 輔助腳本（電腦用）
push_fund*.bat
push_v*.bat
push_v*_result.txt
commit_msg_*.txt

# Local push helper scripts (contain local paths / account names — never commit)
*.vbs
